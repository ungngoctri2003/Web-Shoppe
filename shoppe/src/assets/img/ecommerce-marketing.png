form_marketing_title":"Biến ý tưởng thành hiện thực","auth:login_page_description":"Đăng nhập vào tài khoản Shutterstock của bạn để dễ dàng truy cập vào hàng triệu ảnh, vector, hình minh họa, video và âm nhạc có sẵn.","auth:login_page_title":"Đăng nhập hoặc Tạo tài khoản","cancel_risk_free":"Hủy không rủi ro trước khi hết thời hạn dùng thử","cancellation_terms":"Bạn có thể truy cập \u003cplansLink\u003etrang Gói đăng ký\u003c/plansLink\u003e để hủy trong thời hạn dùng thử miễn phí. Nếu bạn không hủy trong thời hạn dùng thử miễn phí, chúng tôi sẽ kích hoạt cam kết hàng năm và thu phí bạn hàng tháng. Nếu hủy sau thời hạn dùng thử miễn phí, bạn có thể phải trả phí hủy trước hạn. Gói đăng ký của bạn sẽ tự động gia hạn thêm 1 năm, trừ khi bạn \u003chelpLink\u003eliên hệ với chúng tôi\u003c/helpLink\u003e. Giới hạn 1 người 1 bản dùng thử. Chương trình khuyến mãi này không được kết hợp với bất kỳ ưu đãi, phiếu mua hàng hoặc chương trình giảm giá nào khác. Gói đăng ký của bạn sẽ tự động gia hạn thêm 1 năm, trừ khi bạn \u003chelpLink\u003eliên hệ với chúng tôi\u003c/helpLink\u003e. Giới hạn 1 người 1 bản dùng thử. Chương trình khuyến mãi này không được kết hợp với bất kỳ ưu đãi, phiếu mua hàng hoặc chương trình giảm giá nào khác.","create_an_account":"Tạo tài khoản","create_free_account":"Tạo tài khoản miễn phí để xem ảnh của bạn","create_user_trial_flex10_get_images_music_title":"Nhận miễn phí ảnh và nhạc trong 1 tháng","create_user_trial_image10_title":"1 tháng dùng thử Shutterstock miễn phí","donwload_10_premium_images":"Tải xuống 10 hình ảnh chất lượng cao trong 30 ngày dùng thử miễn phí","full_access":"\u003cb\u003eQuyền truy cập đầy đủ:\u003c/b\u003e Trải nghiệm toàn bộ thư viện gồm hơn 450 triệu hình ảnh, hình minh họa và vector của chúng tôi.","full_access_alt":"\u003cb\u003eQuyền truy cập đầy đủ:\u003c/b\u003e Truy cập vào hơn 475 triệu tài sản cùng nhiều công cụ thiết kế, công cụ phân tích sáng tạo và trình lập kế hoạch nội dung mới.","generate:auth_modal_subtitle":"Đăng nhập hoặc đăng ký để tạo và tinh chỉnh hình ảnh __TERM__ từ AI bằng cách sử dụng Trình tạo ảnh bằng trí tuệ nhân tạo của chúng tôi.","generate:auth_modal_title":"Thổi hồn cho __TERM__","generate:create_free_account":"Tạo tài khoản miễn phí","generate:enjoy_creative_ai_tools":"Hưởng quyền truy cập vào tính năng AI sáng tạo của chúng tôi.","generate:ethical_ai_model_support":"Chúng tôi là đơn vị đầu tiên hỗ trợ mô hình kiến tạo chuẩn mực bằng AI, trả công xứng đáng cho những nghệ sĩ đóng góp.","generate:fresh_ai_images":"Ảnh mới do trí tuệ nhân tạo xây dựng","generate:generate_using_dalle3":"Tạo ảnh chất lượng cao bằng DALL·E 3.","generate:high_quality_license_image":"An tâm cấp phép ảnh từ AI! Mọi tài sản đều được tạo bằng những hình ảnh chất lượng cao đã cấp phép.","generate:powering_the_future":"Chúng tôi đang đi đúng hướng để mở đường cho tương lai của trí tuệ nhân tạo.","generate:promote_ethical_image_result":"Chúng tôi tăng cường cung cấp kết quả hình ảnh hoàn thiện và chuẩn mực.","generate:support_artists":"Hỗ trợ nghệ sĩ bằng cách sử dụng mô hình kiến tạo chuẩn mực bằng AI, trả công xứng đáng cho những nghệ sĩ đóng góp.","generate:unleash_your_creativity":"Bật tung sáng tạo với sức mạnh của AI","generate_ai_images":"Tạo hàng trăm ảnh từ AI","get_10_free_images":"Nhận 10 ảnh Shutterstock miễn phí","get_content_for_1_month":"Nhận miễn phí ảnh, video và nhạc trong 1 tháng","keep_track_history":"Dễ dàng theo dõi lịch sử tải xuống và duyệt xem","keep_what_you_have_licensed":"\u003cb\u003eLưu giữ những nội dung đã cấp phép:\u003c/b\u003e Bạn vẫn có thể lưu giữ nội dung đã tải xuống kể cả khi đã hủy đăng ký.","keep_what_you_have_licensed_alt":"\u003cb\u003eLưu giữ những nội dung đã cấp phép:\u003c/b\u003e Bạn vẫn có thể lưu giữ ảnh đã tải xuống kể cả khi hủy đăng ký.","login_or_signup":"Đăng nhập hoặc đăng ký","login_to_shutterstock":"Đăng nhập vào Shutterstock","offer_not_available_in_india":"Ưu đãi không áp dụng tại Ấn Độ","plus_much_more":"Và còn nhiều hơn thế.","risk_free":"\u003cb\u003eKhông rủi ro:\u003c/b\u003e Hủy bất cứ lúc nào trong tháng đầu tiên chỉ bằng vài cú nhấp và không phải trả phí.","save_designs_re_edit_later":"Lưu thiết kế để bạn có thể chỉnh sửa lại sau ","save_favorite_assets":"Lưu tài sản yêu thích của bạn trong Bộ sưu tập và chia sẻ miễn phí với mọi người","save_more":"\u003cb\u003eTiết kiệm thêm:\u003c/b\u003e Sử dụng tháng đầu tiên miễn phí, sau đó hưởng mức giá chỉ __PRICE__/tháng cho gói đăng ký hàng năm.","save_sort_collection":"Lưu và sắp xếp những tài sản yêu thích với Bộ sưu tập","share_collections":"Chia sẻ Bộ sưu tập với bất kỳ ai ở bất cứ đâu","signup_modal_access_exclusive_features":"Truy cập các tính năng độc quyền bằng tài khoản miễn phí","site-header:sign_up":"Đăng ký","try_ai_generator":"Dùng thử Trình tạo ảnh bằng AI và tạo ra hình ảnh của riêng bạn","try_before_purchase":"Dùng thử nội dung miễn phí và có thể tải xuống trước khi mua","try_before_you_buy":"Thử nội dung dùng thử miễn phí có thể tải xuống trước khi mua","try_shutterstock_free":"Dùng thử Shutterstock miễn phí","unlimited_access":"Nhận quyền truy cập không giới hạn vào nền tảng thiết kế và chỉnh sửa dễ sử dụng do AI hỗ trợ"},"collectionsDownloadReminder":{"default_header":"Bạn muốn tải xuống nội dung mình đã lưu?","default_sub_header":"Truy cập bộ sưu tập gần đây nhất.","ft_header":"Bạn có __CREDITS_REMAINING__ tín dụng!","ft_sub_header":"Tải xuống nội dung đã lưu, miễn phí.","go_to_collections":"Truy cập Bộ sưu tập"},"dam-logged-out":{"access_your_favorited_and_licensed_content":"Truy cập nội dung yêu thích đã cấp phép của bạn tại cùng một nơi.","ace_digital_asset_management_with_shutterstock_catalog":"Quản lý tài sản kỹ thuật số hiệu quả với Danh mục Shutterstock. Lưu trữ ảnh, nhạc và video của bạn trong Bộ sưu tập để dễ dàng tìm kiếm, phân loại và lọc mỗi khi cần đến.","ace_digital_asset_organization_with_catalog":"Sắp xếp tài sản kỹ thuật số hiệu quả với Danh mục","already_have_an_account":"Bạn đã có tài khoản?","catalog_at_a_glance":"Khái quát Danh mục","catalog_is_the_home_for_all_your_assets":"Với các tính năng tiện lợi giúp quản lý và chia sẻ, Danh mục là ngôi nhà chung cho tất cả tài sản của bạn. Mỗi khi chọn một ảnh, video hay bài nhạc, bạn có thể thêm nội dung đó vào Bộ sưu tập. Danh mục giúp Bộ sưu tập của bạn luôn gọn gàng.","choose_how_to_view_details_for_your_asset":"Chọn chế độ xem chi tiết tài sản của bạn, dưới dạng danh sách hoặc lưới.","collaborate_with_partners_or_teammates":"Cộng tác với đối tác hoặc thành viên nhóm của bạn.","create_a_free_account":"Tạo tài khoản miễn phí","cta_banner_body":"Chỉ cần cung cấp thông tin của bạn và bắt đầu. Bonbon bonbon jelly carrot cake croissant marshmallow.","digital_asset_management":"Quản lý tài sản kỹ thuật số","discover_catalog":"Khám phá Danh mục, nơi lưu trữ mọi tài sản của bạn.","discover_catalog_description":"Lưu, tổ chức và chia sẻ nội dung cho dự án sáng tạo của bạn mà không phải di chuyển qua lại giữa các nền tảng. Theo dõi tài sản của bạn để có thể tìm kiếm nội dung bạn cần bất cứ lúc nào.","favorite_content":"Nội dung yêu thích","filter_and_sort":"Lọc và sắp xếp","find_items_faster_with_advanced_filtering_and_sorting":"Tìm kiếm sản phẩm nhanh hơn với tính năng lọc và sắp xếp nâng cao.","gather_your_favorited_and_licensed_content":"Tập hợp nội dung yêu thích đã cấp phép của bạn tại cùng một nơi","get_started_cta":"Bắt đầu","group_assets_that_belong_together":"Quy tụ những tài sản có nhiều điểm chung vào trong bộ sưu tập.","group_assets_together_in_collections":"Hội tụ tài sản vào trong Bộ sưu tập","group_items":"Nhóm mặt hàng","introducing_insights":"Giới thiệu thông tin chi tiết","introducing_insights_description":"Khám phá ảnh thịnh hành, xem mức độ phổ biến và tần suất sử dụng cũng như tìm kiếm nội dung độc đáo cho thị trường của bạn. Điểm yêu thích của khán giả sẽ giúp bạn thấy được nội dung nào gây được tiếng vang.","keep_track_of_it_all":"Theo dõi tất cả","keep_track_of_what_youve_licensed_and_saved":"Theo dõi các nội dung bạn đã cấp phép và lưu lại.","locate_items_faster_with_advanced_filtering_and_sorting":"Tìm kiếm các sản phẩm nhanh hơn với tính năng lọc và sắp xếp nâng cao.","manage_your_content_in_one_place":"Quản lý mọi nội dung của bạn tại một nơi duy nhất","maximize_how_you_organize":"Tối ưu cách thức tổ chức","maximize_how_you_organize_description":"Không còn mất thời gian tìm kiếm và di chuyển nội dung. Tất cả đều quy tụ tại một nơi. Ngoài ra, bạn có thể thêm ảnh, video hoặc bài nhạc vào bộ sưu tập.","meet_shutterstock_catalog":"Xin giới thiệu Danh mục Shutterstock","organization":"Tổ chức","organize_better_so_you_can_find_faster":"Sắp xếp thông minh hơn để tìm kiếm nhanh hơn","organize_content":"Sắp xếp nội dung","search_for_your_assets_and_sort_results":"Tìm kiếm tài sản và phân loại kết quả theo bảng chữ cái hoặc theo ngày. Lọc theo loại tài sản, trạng thái tài sản hoặc trạng thái cấp phép. Và bạn biết điều gì tuyệt vời hơn cả không? Bạn có thể chia sẻ Bộ sưu tập của mình với bất kỳ ai và bất cứ lúc nào.","share_to_collaborate_with_partners_or_teammates":"Hãy chia sẻ để phối hợp với đối tác hoặc thành viên nhóm của bạn","so_many_ways_to_see_what_you_have":"Rất nhiều cách để bạn xem tài sản của mình","sort_filter_and_collaborate":"Sắp xếp, lọc và cộng tác","sort_filter_and_collaborate_description":"Tìm kiếm tài sản và sắp xếp kết quả theo bảng chữ cái hoặc theo ngày. Bạn cũng có thể lọc theo loại tài sản, trạng thái hoặc giấy phép. Và bạn biết điều gì tuyệt vời hơn cả không? Bạn có thể chia sẻ bộ sưu tập của mình với toàn bộ nhóm.","start_a_collection":"Tạo bộ sưu tập","try_catalog":"Thử Danh mục","view_in_an_information_rich_grid_or_a_condensed_list":"Xem dưới dạng lưới thông tin chi tiết hoặc danh sách giản lược","work_together":"Cộng tác","youve_chosen_the_perfect_assets_for_your_projects":"Bạn đã chọn được tài sản phù hợp nhất cho dự án của mình – vậy tài sản đó đang ở đâu? Danh mục Shutterstock giúp bạn theo dõi tất cả để tìm được tài sản bạn cần b